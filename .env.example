# ---------- Database ----------
POSTGRES_USER=airsoft
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=airsoft

# Used by backend (auto-generated in docker-compose; only set manually for local dev)
# DATABASE_URL=postgresql+psycopg://airsoft:CHANGE_ME_strong_password@localhost:5432/airsoft

# ---------- Security ----------
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- URLs ----------
# Public site URL (used to build payment callback URLs)
SITE_URL=http://localhost
# API URL that the browser uses (through nginx)
NEXT_PUBLIC_API_URL=http://localhost/api
# Comma separated CORS origins
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# ---------- Initial admin user (created on first start) ----------
ADMIN_PHONE=09120000000
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_NAME=Admin

# ---------- Optional: SMS (Kavenegar) ----------
KAVENEGAR_API_KEY=
SMS_SENDER=
